# Generated build artifacts (recreated by `ov box generate` / `ov box build`)
.build/
# Generated context-ignore files (podman reads .containerignore, docker .dockerignore)
.containerignore
.dockerignore
# Eval run scratch
.eval/
# VM / disk-image build outputs
output/
# Editor scratch
*.swp
*~

# Migration rollback backups (ov migrate writes <file>.bak.<unix-ts>)
*.bak
*.bak.*

# Syncthing conflict copies — per-machine, ephemeral, resolved by hand; never versioned.
*.sync-conflict-*
